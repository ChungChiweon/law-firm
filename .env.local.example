# ── Supabase ────────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (선택) 서버 전용 — 관리자 API에서 RLS 우회 시 사용
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI ───────────────────────────────────────────────
# AI 상담 요약 기능 (없으면 mock 모드로 동작)
# OpenAI 대시보드 → API Keys 에서 발급
# OPENAI_API_KEY=sk-...

# ── 관리자 접근 제한 ─────────────────────────────────────
# /admin 페이지 접근 비밀번호 (MVP 보호장치)
# 미설정 시: 로컬 개발 환경에서는 비밀번호 없이 접근 가능
# 실제 운영 전: 더 강한 인증 방식으로 교체 권장
ADMIN_ACCESS_PASSWORD=change-this-password

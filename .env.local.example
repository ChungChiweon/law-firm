# ── Supabase ────────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 — 관리자 CRM (GET/PATCH) RLS 우회에 필요
# Supabase 대시보드 → Project Settings → API → service_role key
# 주의: 절대 브라우저에 노출 금지 (NEXT_PUBLIC_ 접두사 없음)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI ───────────────────────────────────────────────
# AI 상담 요약 기능 (없으면 mock 모드로 동작)
# OpenAI 대시보드 → API Keys 에서 발급
# OPENAI_API_KEY=sk-...

# ── 관리자 접근 제한 ─────────────────────────────────────
# /admin 페이지 접근 비밀번호 (MVP 보호장치)
# 미설정 시: 로컬 개발 환경에서는 비밀번호 없이 접근 가능
# 실제 운영 전: 더 강한 인증 방식으로 교체 권장
ADMIN_ACCESS_PASSWORD=change-this-password

# ── 새 상담 접수 알림 ────────────────────────────────────
# 상담이 들어오면 변호사에게 즉시 통지합니다. 설정한 채널만 발송됩니다.
# 아무것도 설정하지 않아도 접수 자체는 정상 동작합니다.

# Slack Incoming Webhook (가장 간단 — 채널에 앱 추가 후 URL 복사)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 이메일 알림 (Resend — resend.com 에서 API Key 발급)
# RESEND_API_KEY=re_...
# NOTIFY_EMAIL_TO=lawyer@your-firm.kr
# NOTIFY_EMAIL_FROM=alert@your-verified-domain.kr   # 미설정 시 onboarding@resend.dev
